[Unit]
Description=Crawler Honeypot Flask Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/crawler-honeypot
EnvironmentFile=/opt/crawler-honeypot/.env
ExecStart=/opt/crawler-honeypot/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
